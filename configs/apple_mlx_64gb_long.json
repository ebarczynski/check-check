{
  "name": "apple_mlx_64gb_long",
  "description": "Long-running MLX-native preset for Apple Silicon systems with larger unified memory.",
  "graph": {
    "num_nodes": 80000,
    "num_relations": 8,
    "edges_per_relation": 750000,
    "input_dim": 256,
    "num_classes": 64,
    "train_fraction": 0.8,
    "seed": 17
  },
  "model": {
    "hidden_dim": 512,
    "num_layers": 4,
    "dropout": 0.1,
    "edge_chunk_size": 12288,
    "ffn_multiplier": 2
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0007,
    "weight_decay": 0.01
  },
  "run": {
    "epochs": 400,
    "min_duration_sec": 3600,
    "warmup_epochs": 5,
    "log_every": 1,
    "precision": "fp32",
    "results_dir": "results",
    "tf32": false
  }
}
