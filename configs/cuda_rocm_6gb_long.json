{
  "name": "cuda_rocm_6gb_long",
  "description": "Long-running preset sized for 6 GB class AMD ROCm and NVIDIA CUDA dGPUs.",
  "graph": {
    "num_nodes": 60000,
    "num_relations": 8,
    "edges_per_relation": 400000,
    "input_dim": 192,
    "num_classes": 48,
    "train_fraction": 0.8,
    "seed": 17
  },
  "model": {
    "hidden_dim": 384,
    "num_layers": 3,
    "dropout": 0.1,
    "edge_chunk_size": 8192,
    "ffn_multiplier": 2
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0008,
    "weight_decay": 0.01
  },
  "run": {
    "epochs": 600,
    "min_duration_sec": 3600,
    "warmup_epochs": 5,
    "log_every": 1,
    "precision": "fp32",
    "results_dir": "results",
    "tf32": true
  }
}