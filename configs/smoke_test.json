{
  "name": "smoke_test",
  "description": "Small validation workload to verify backend and driver setup.",
  "graph": {
    "num_nodes": 4096,
    "num_relations": 4,
    "edges_per_relation": 20000,
    "input_dim": 64,
    "num_classes": 16,
    "train_fraction": 0.8,
    "seed": 17
  },
  "model": {
    "hidden_dim": 128,
    "num_layers": 2,
    "dropout": 0.1,
    "edge_chunk_size": 4096,
    "ffn_multiplier": 2
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.001,
    "weight_decay": 0.01
  },
  "run": {
    "epochs": 3,
    "min_duration_sec": 0,
    "warmup_epochs": 1,
    "log_every": 1,
    "precision": "fp32",
    "results_dir": "results",
    "tf32": true
  }
}
