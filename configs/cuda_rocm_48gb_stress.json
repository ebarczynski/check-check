{
  "name": "cuda_rocm_48gb_stress",
  "description": "Heavier preset for 48 GB class NVIDIA CUDA and AMD ROCm accelerators.",
  "graph": {
    "num_nodes": 180000,
    "num_relations": 16,
    "edges_per_relation": 1500000,
    "input_dim": 320,
    "num_classes": 96,
    "train_fraction": 0.8,
    "seed": 17
  },
  "model": {
    "hidden_dim": 1024,
    "num_layers": 5,
    "dropout": 0.1,
    "edge_chunk_size": 49152,
    "ffn_multiplier": 2
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0005,
    "weight_decay": 0.01
  },
  "run": {
    "epochs": 500,
    "min_duration_sec": 5400,
    "warmup_epochs": 5,
    "log_every": 1,
    "precision": "fp32",
    "results_dir": "results",
    "tf32": true
  }
}
